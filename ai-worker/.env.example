# FastAPI
APP_NAME="Agency AI Worker"
APP_VERSION="0.1.0"
DEBUG=false

# Servidor
WORKER_HOST=0.0.0.0
WORKER_PORT=8001

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379

# Eventos
REDIS_EVENTS_CHANNEL=agency_events

# LLM APIs (Requerido para CrewAI)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CrewAI Configuration
CREW_VERBOSE=true
CREW_MEMORY=true
CREW_CACHE=true

# Logging
LOG_LEVEL=info
